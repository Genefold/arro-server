# arro-server environment variables
# Copy to .env and adjust values for your deployment.

# ---------------------------------------------------------------------------
# Deployment tier
# 'development' (default) — open CORS, no API key required, human log format
# 'production'            — CORS restriction enforced, API key required, JSON logs
# ---------------------------------------------------------------------------
ARRO_SERVER_ENV=development

# ---------------------------------------------------------------------------
# Data roots
# Comma-separated label=path pairs pointing to Zarr v3 dataset directories.
# ---------------------------------------------------------------------------
ARRO_SERVER_DATA_ROOTS=main=./data

# ---------------------------------------------------------------------------
# ArrowSpace index store
# ---------------------------------------------------------------------------
ARRO_SERVER_ARROWSPACE_INDEX_STORE=./storage
ARRO_SERVER_INDEX_CACHE_SIZE=8

# ---------------------------------------------------------------------------
# Auth
# Required when ARRO_SERVER_ENV=production.
# Generate with: openssl rand -hex 32
# Clients send:  X-API-Key: <value>
# ---------------------------------------------------------------------------
ARRO_SERVER_API_KEY=

# ---------------------------------------------------------------------------
# Rate limiting  (write endpoints only)
# Uses limits library syntax: '30/minute', '5/second', '' to disable.
# ---------------------------------------------------------------------------
ARRO_SERVER_RATE_LIMIT_WRITE=30/minute

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
ARRO_SERVER_HOST=0.0.0.0
ARRO_SERVER_PORT=8000
ARRO_SERVER_RELOAD=false
ARRO_SERVER_LOG_LEVEL=info

# Structured JSON log lines (one JSON object per line).
# Automatically forced to true when ARRO_SERVER_ENV=production.
ARRO_SERVER_LOG_JSON=false

# ---------------------------------------------------------------------------
# CORS
# MUST NOT be '*' when ARRO_SERVER_ENV=production.
# Example: ARRO_SERVER_CORS_ORIGINS=https://app.example.com,https://admin.example.com
# ---------------------------------------------------------------------------
ARRO_SERVER_CORS_ORIGINS=*

# Allow cookies / Authorization headers in cross-origin requests.
# Requires cors_origins to be set to explicit origin(s), not '*'.
ARRO_SERVER_CORS_ALLOW_CREDENTIALS=false

# ---------------------------------------------------------------------------
# Features
# ---------------------------------------------------------------------------
ARRO_SERVER_SERVE_FRONTEND=true
ARRO_SERVER_MAX_WINDOW=10000
ARRO_SERVER_DEFAULT_WINDOW=1000
