# Copy to .env and tailor.
# Comma-separated list. Each entry is `path` or `label=path`.
ARROSPACE_DATA_ROOTS=main=./example_data

# Allowed CORS origins (comma-separated). "*" disables restriction.
ARROSPACE_CORS_ORIGINS=*

# Default page size for /data requests when limit is omitted.
ARROSPACE_DEFAULT_WINDOW=100

# Hard cap (in elements) on a single /data or /slice response.
ARROSPACE_MAX_WINDOW=100000

# Whether to mount the bundled frontend at /ui (true|false).
ARROSPACE_SERVE_FRONTEND=true

# Bind host/port for `python -m arrospace_server`.
ARROSPACE_HOST=0.0.0.0
ARROSPACE_PORT=8000
ARROSPACE_RELOAD=0
