# arro-server environment variables
# Copy to .env and adjust values for your deployment.

# ---------------------------------------------------------------------------
# Data roots
# Comma-separated label=path pairs pointing to Zarr v3 dataset directories.
# Example: ARRO_SERVER_DATA_ROOTS=main=/data/zarr,aux=/data/aux
# ---------------------------------------------------------------------------
ARRO_SERVER_DATA_ROOTS=main=./data

# ---------------------------------------------------------------------------
# ArrowSpace index store  (Phase 2)
# Writable directory where persisted Parquet index files are stored.
# Indices survive server restarts — no need to POST /index again.
# Maps to a named Docker volume in compose.yaml (arrow_index_store).
# ---------------------------------------------------------------------------
ARRO_SERVER_ARROWSPACE_INDEX_STORE=./storage

# Legacy alias (Phase 1) — still accepted, ARROWSPACE_INDEX_STORE takes precedence.
# ARRO_SERVER_INDEX_STORE=./storage

# In-memory LRU cache size (number of ArrowSpace objects kept in RAM).
ARRO_SERVER_INDEX_CACHE_SIZE=8

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
ARRO_SERVER_HOST=0.0.0.0
ARRO_SERVER_PORT=8000
ARRO_SERVER_RELOAD=false
ARRO_SERVER_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# CORS  — restrict to your frontend origin in production
# ---------------------------------------------------------------------------
ARRO_SERVER_CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Features
# ---------------------------------------------------------------------------
ARRO_SERVER_SERVE_FRONTEND=true
ARRO_SERVER_MAX_WINDOW=10000
